        "23738779-93a8-4a1b-aa4a-382808fc8419": {
          "type": "column",
          "settings": {
            "show_image": true,
            "title": "Sustability",
            "heading_size": "h4",
            "text": "<p>From using recycled materials to reducing energy consumption, we're constantly seeking innovative ways to make our brand sustainable.</p>",
            "text_size": "medium",
